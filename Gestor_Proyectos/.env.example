# Copia este archivo como .env (o configura estas variables en tu entorno/IDE)
# NUNCA commitees el archivo .env real

# --- JWT ---
# Genera una cadena aleatoria larga (min 32 chars), ej: openssl rand -hex 32
JWT_SECRET=cambia-esto-por-una-cadena-aleatoria-larga-en-produccion
JWT_EXPIRATION_MS=86400000

# --- Base de datos ---
DB_URL=jdbc:mysql://localhost:3306/springdb?serverTimezone=UTC
DB_USERNAME=oscar
DB_PASSWORD=tu_password_aqui

# --- Redis ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# --- GitHub API ---
# Genera un token en: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_USERNAME=tu_usuario_github

# --- GitLab API ---
# Genera un token en: https://gitlab.com/-/user_settings/personal_access_tokens
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# --- StackOverflow API ---
# Registra una app en: https://stackapps.com/apps/oauth/register
STACKOVERFLOW_KEY=tu_key_aqui

# --- Mail (Gmail SMTP) ---
# Usa una App Password de Google, NO tu contraseña normal
# Activa 2FA y genera una en: https://myaccount.google.com/apppasswords
MAIL_USERNAME=tu_email@gmail.com
MAIL_PASSWORD=xxxx_xxxx_xxxx_xxxx
