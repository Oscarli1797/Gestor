# ────────────────────────────────────────────────────────────────
# 复制此文件为 .env 并填入你的值
#   cp .env.example .env
# docker-compose 会自动读取 .env
# ────────────────────────────────────────────────────────────────

# ── 数据库 ──────────────────────────────────────────────────────
DB_PASSWORD=devpassword
MYSQL_ROOT_PASSWORD=rootpass

# ── JWT（至少 32 个字符）────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars!!

# ── GitHub（搜索和开发者档案必填）──────────────────────────────
# 获取：https://github.com/settings/tokens
# 权限：read:user, read:org
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 邮件（可选，测试时可跳过，直接从 Redis 读验证码）────────────
# Gmail 需要开启两步验证后生成"应用专用密码"
MAIL_USERNAME=
MAIL_PASSWORD=

# ── Google OAuth2（可选）────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Claude AI（可选，不填则跳过 AI 评分）────────────────────────
ANTHROPIC_API_KEY=

# ── Stripe（可选，不填则支付功能不可用）─────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
